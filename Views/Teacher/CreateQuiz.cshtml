@{
    ViewData["Title"] = "Create New Quiz";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <h5 class="mb-4">
                <i class="fas fa-plus-circle me-2" style="color:#6c63ff;"></i>
                Create New Quiz
            </h5>

            <form asp-action="CreateQuiz" method="post">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" style="color:#a0a0b0;">Quiz Title</label>
                        <input name="Title" class="form-control"
                               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                               placeholder="e.g. Python Basics Quiz" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="color:#a0a0b0;">Description</label>
                        <textarea name="Description" class="form-control" rows="3"
                                  style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                                  placeholder="Brief description of this quiz"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="color:#a0a0b0;">Subject</label>
                        <input name="Subject" class="form-control"
                               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                               placeholder="e.g. Computer Science" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="color:#a0a0b0;">Time Limit (Minutes)</label>
                        <input name="TimeLimitMinutes" type="number" class="form-control"
                               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                               value="30" min="5" max="180" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="color:#a0a0b0;">Total Marks</label>
                        <input name="TotalMarks" type="number" class="form-control"
                               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                               placeholder="e.g. 100" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="color:#a0a0b0;">Passing Marks</label>
                        <input name="PassingMarks" type="number" class="form-control"
                               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
                        color:white;border-radius:10px;padding:12px;"
                               placeholder="e.g. 50" required />
                    </div>
                    <div class="col-12 mt-3">
                        <button type="submit" class="btn btn-primary px-5">
                            <i class="fas fa-save me-2"></i>Create Quiz & Add Questions
                        </button>
                        <a asp-action="MyQuizzes" class="btn btn-outline-secondary ms-2">
                            Cancel
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>