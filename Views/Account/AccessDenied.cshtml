@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0f0f23;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        .card {
            background: #16213e;
            border: 1px solid rgba(245,0,87,0.3);
            border-radius: 20px;
            padding: 50px;
            text-align: center;
            max-width: 450px;
        }
        .icon { font-size: 4rem; color: #f50057; margin-bottom: 20px; }
        h2 { color: white; }
        p { color: #888; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon"><i class="fas fa-ban"></i></div>
        <h2>Access Denied!</h2>
        <p>You do not have access to this page.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-3">
            <i class="fas fa-arrow-left me-2"></i>Go to Login Page
        </a>
    </div>
</body>
</html>