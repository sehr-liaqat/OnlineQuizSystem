@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="icon" style="background:rgba(108,99,255,0.2);">
                <i class="fas fa-book-open" style="color:#6c63ff;"></i>
            </div>
            <h3>@ViewBag.AvailableQuizzes</h3>
            <p>Available Quizzes</p>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="icon" style="background:rgba(255,165,0,0.2);">
                <i class="fas fa-pen" style="color:orange;"></i>
            </div>
            <h3>@ViewBag.MyAttempts</h3>
            <p>Total Attempts</p>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="icon" style="background:rgba(0,200,150,0.2);">
                <i class="fas fa-trophy" style="color:#00c896;"></i>
            </div>
            <h3>@ViewBag.PassedQuizzes</h3>
            <p>Quizzes Passed</p>
        </div>
    </div>
</div>

<div class="content-card">
    <h5 class="mb-4">
        <i class="fas fa-history me-2" style="color:#6c63ff;"></i>Recent Attempts
    </h5>

    @if (ViewBag.RecentAttempts != null &&
         ((List<OnlineQuizSystem.Models.QuizAttempt>)ViewBag.RecentAttempts).Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Quiz Title</th>
                        <th>Subject</th>
                        <th>Marks</th>
                        <th>Result</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attempt in
                        (List<OnlineQuizSystem.Models.QuizAttempt>)ViewBag.RecentAttempts)
                    {
                        <tr>
                            <td style="color:white;font-weight:600;">
                                @attempt.Quiz?.Title
                            </td>
                            <td style="color:#888;">@attempt.Quiz?.Subject</td>
                            <td>
                                <span style="color:#6c63ff;font-weight:700;">
                                    @attempt.ObtainedMarks / @attempt.Quiz?.TotalMarks
                                </span>
                            </td>
                            <td>
                                @if (attempt.IsPassed)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i>Passed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-times me-1"></i>Failed
                                    </span>
                                }
                            </td>
                            <td style="color:#888;">
                                @attempt.AttemptedAt.ToString("dd MMM yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <i class="fas fa-inbox fa-3x mb-3" style="color:#888;"></i>
            <p style="color:#888;">No quiz attempts yet.</p>
            <a asp-controller="Student" asp-action="AvailableQuizzes" class="btn btn-primary">
                <i class="fas fa-book-open me-2"></i>Browse Quizzes
            </a>
        </div>
    }
</div>