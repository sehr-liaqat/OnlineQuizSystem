@model IEnumerable<OnlineQuizSystem.Models.Quiz>
@{
    ViewData["Title"] = "Manage Quizzes";
}

<div class="content-card">
    <h5 class="mb-4">
        <i class="fas fa-list me-2" style="color:#6c63ff;"></i>All Quizzes
    </h5>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3" style="color:#888;"></i>
            <p style="color:#888;">No quizzes created yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Subject</th>
                        <th>Total Marks</th>
                        <th>Time Limit</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quiz in Model)
                    {
                        <tr>
                            <td style="color:white;font-weight:600;">@quiz.Title</td>
                            <td style="color:#888;">@quiz.Subject</td>
                            <td>
                                <span style="color:#6c63ff;font-weight:600;">
                                    @quiz.TotalMarks
                                </span>
                            </td>
                            <td style="color:#888;">@quiz.TimeLimitMinutes mins</td>
                            <td>
                                @if (quiz.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td style="color:#888;">
                                @quiz.CreatedAt.ToString("dd MMM yyyy")
                            </td>
                            <td>
                                <a asp-action="QuizDetail" asp-route-id="@quiz.Id"
                                       class="btn btn-sm btn-primary me-1">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a asp-action="ToggleQuiz" asp-route-id="@quiz.Id"
                                       class="btn btn-sm @(quiz.IsActive ? "btn-warning" : "btn-success")">
                                    <i class="fas @(quiz.IsActive ? "fa-ban" : "fa-check")"></i>
                                    @(quiz.IsActive ? "Disable" : "Enable")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>