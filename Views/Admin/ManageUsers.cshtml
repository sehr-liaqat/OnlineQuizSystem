@model IEnumerable<OnlineQuizSystem.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5><i class="fas fa-users me-2" style="color:#6c63ff;"></i>All Users</h5>
        <input type="text" id="searchInput" class="form-control w-25"
               placeholder="Search users..."
               style="background:#0f0f23;border:1px solid rgba(108,99,255,0.3);
        color:white;border-radius:8px;" />
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover" id="usersTable">
            <thead>
                <tr style="border-color:rgba(108,99,255,0.3);">
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:32px;height:32px;border-radius:50%;
                                    background:linear-gradient(135deg,#6c63ff,#f50057);
                                    display:flex;align-items:center;justify-content:center;
                                    color:white;font-weight:700;font-size:0.8rem;">
                                    @user.FullName.Substring(0, 1).ToUpper()
                                </div>
                                @user.FullName
                            </div>
                        </td>
                        <td style="color:#888;">@user.Email</td>
                        <td>
                            <span class="badge-role badge-@user.Role.ToLower()">
                                @user.Role
                            </span>
                        </td>
                        <td style="color:#888;">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            @if (user.Id != 1)
                            {
                                <a asp-action="ToggleUser" asp-route-id="@user.Id"
                                       class="btn btn-sm @(user.IsActive ? "btn-warning" : "btn-success") me-1">
                                    <i class="fas @(user.IsActive ? "fa-ban" : "fa-check")"></i>
                                </a>
                                <a asp-action="DeleteUser" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Sure ho? User delete ho jayega!')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                            else
                            {
                                <span style="color:#888;font-size:0.8rem;">Protected</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const val = this.value.toLowerCase();
            document.querySelectorAll('#usersTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        });
    </script>
}