@model OnlineQuizSystem.Models.Quiz
@{
    ViewData["Title"] = "Quiz Detail";
}

<div class="row g-4">
    <!-- Quiz Info -->
    <div class="col-lg-4">
        <div class="content-card">
            <h5 class="mb-4">
                <i class="fas fa-info-circle me-2" style="color:#6c63ff;"></i>
                Quiz Information
            </h5>
            <div style="font-size:0.9rem;">
                <div class="mb-3">
                    <div style="color:#888;">Title</div>
                    <div style="color:white;font-weight:600;">@Model.Title</div>
                </div>
                <div class="mb-3">
                    <div style="color:#888;">Subject</div>
                    <div style="color:white;font-weight:600;">@Model.Subject</div>
                </div>
                <div class="mb-3">
                    <div style="color:#888;">Description</div>
                    <div style="color:white;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description." : Model.Description)
                    </div>
                </div>
                <div class="mb-3">
                    <div style="color:#888;">Created By</div>
                    <div style="color:white;font-weight:600;">
                        @Model.CreatedByUser?.FullName
                    </div>
                </div>
                <div class="mb-3">
                    <div style="color:#888;">Created On</div>
                    <div style="color:white;">
                        @Model.CreatedAt.ToString("dd MMM yyyy")
                    </div>
                </div>
                <hr style="border-color:rgba(108,99,255,0.2);" />
                <div class="row text-center">
                    <div class="col-4">
                        <div style="color:#6c63ff;font-size:1.4rem;font-weight:700;">
                            @Model.TotalMarks
                        </div>
                        <div style="color:#888;font-size:0.75rem;">Total Marks</div>
                    </div>
                    <div class="col-4">
                        <div style="color:#00c896;font-size:1.4rem;font-weight:700;">
                            @Model.PassingMarks
                        </div>
                        <div style="color:#888;font-size:0.75rem;">Passing</div>
                    </div>
                    <div class="col-4">
                        <div style="color:orange;font-size:1.4rem;font-weight:700;">
                            @Model.TimeLimitMinutes
                        </div>
                        <div style="color:#888;font-size:0.75rem;">Minutes</div>
                    </div>
                </div>
                <hr style="border-color:rgba(108,99,255,0.2);" />
                <div class="row text-center">
                    <div class="col-6">
                        <div style="color:white;font-size:1.4rem;font-weight:700;">
                            @ViewBag.TotalAttempts
                        </div>
                        <div style="color:#888;font-size:0.75rem;">Total Attempts</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#00c896;font-size:1.4rem;font-weight:700;">
                            @ViewBag.PassedCount
                        </div>
                        <div style="color:#888;font-size:0.75rem;">Passed</div>
                    </div>
                </div>
                <hr style="border-color:rgba(108,99,255,0.2);" />
                <div class="d-flex gap-2">
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") p-2">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="ManageQuizzes" class="btn btn-outline-secondary w-100">
                <i class="fas fa-arrow-left me-2"></i>Back to Quizzes
            </a>
        </div>
    </div>

    <!-- Questions List -->
    <div class="col-lg-8">
        <div class="content-card">
            <h5 class="mb-4">
                <i class="fas fa-question-circle me-2" style="color:#6c63ff;"></i>
                Questions (@Model.Questions.Count)
            </h5>

            @if (!Model.Questions.Any())
            {
                <div class="text-center py-4">
                    <i class="fas fa-inbox fa-2x mb-2" style="color:#888;"></i>
                    <p style="color:#888;">No questions added to this quiz yet.</p>
                </div>
            }
            else
            {
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions.ElementAt(i);
                    <div style="background:#0f0f23;border-radius:12px;padding:20px;
                        margin-bottom:15px;border:1px solid rgba(108,99,255,0.15);">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div style="background:linear-gradient(135deg,#6c63ff,#f50057);
                                width:30px;height:30px;border-radius:50%;
                                display:flex;align-items:center;justify-content:center;
                                color:white;font-weight:700;font-size:0.85rem;flex-shrink:0;">
                                @(i + 1)
                            </div>
                            <div>
                                <div style="color:white;font-weight:600;">@q.QuestionText</div>
                                <small style="color:#888;">Marks: @q.Marks</small>
                            </div>
                        </div>

                        <div class="row g-2 ps-5">
                            @foreach (var opt in q.Options)
                            {
                                <div class="col-md-6">
                                    <div style="background:@(opt.IsCorrect ? "rgba(0,200,150,0.15)" : "#16213e");
                                        border:1px solid @(opt.IsCorrect ? "rgba(0,200,150,0.4)" : "rgba(108,99,255,0.15)");
                                        border-radius:8px;padding:8px 12px;
                                        display:flex;align-items:center;gap:8px;">
                                        @if (opt.IsCorrect)
                                        {
                                            <i class="fas fa-check-circle" style="color:#00c896;"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-circle" style="color:#444;font-size:0.6rem;"></i>
                                        }
                                        <span style="color:@(opt.IsCorrect ? "#00c896" : "#a0a0b0");
                                            font-size:0.85rem;">
                                            @opt.OptionText
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>