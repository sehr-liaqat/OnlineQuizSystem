<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Quiz System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
            :root {
                --primary: #6c63ff;
                --secondary: #f50057;
                --dark: #1a1a2e;
                --card-bg: #16213e;
                --sidebar-width: 250px;
            }

            body {
                background: #0f0f23;
                color: #e0e0e0;
                font-family: 'Segoe UI', sans-serif;
                min-height: 100vh;
            }

            /* ── Sidebar ── */
            .sidebar {
                width: var(--sidebar-width);
                background: var(--dark);
                min-height: 100vh;
                position: fixed;
                left: 0; top: 0;
                z-index: 1000;
                border-right: 1px solid rgba(108,99,255,0.3);
                transition: all 0.3s;
            }

            .sidebar-brand {
                padding: 20px;
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                text-align: center;
            }

            .sidebar-brand h4 {
                color: white;
                margin: 0;
                font-weight: 700;
                font-size: 1.1rem;
            }

            .sidebar-brand p {
                color: rgba(255,255,255,0.8);
                margin: 0;
                font-size: 0.75rem;
            }

            .sidebar .nav-link {
                color: #a0a0b0;
                padding: 12px 20px;
                border-radius: 8px;
                margin: 3px 10px;
                transition: all 0.3s;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .sidebar .nav-link:hover,
            .sidebar .nav-link.active {
                background: rgba(108,99,255,0.2);
                color: var(--primary);
                transform: translateX(5px);
            }

            .sidebar .nav-link i {
                width: 20px;
                text-align: center;
            }

            /* ── Main Content ── */
            .main-content {
                margin-left: var(--sidebar-width);
                padding: 0;
                min-height: 100vh;
            }

            /* ── Topbar ── */
            .topbar {
                background: var(--dark);
                padding: 15px 25px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 1px solid rgba(108,99,255,0.3);
                position: sticky;
                top: 0;
                z-index: 999;
            }

            .topbar .user-info {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .topbar .avatar {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 700;
                font-size: 0.9rem;
            }

            /* ── Cards ── */
            .stat-card {
                background: var(--card-bg);
                border-radius: 16px;
                padding: 25px;
                border: 1px solid rgba(108,99,255,0.2);
                transition: transform 0.3s, box-shadow 0.3s;
            }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 30px rgba(108,99,255,0.2);
            }

            .stat-card .icon {
                width: 55px;
                height: 55px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.4rem;
                margin-bottom: 15px;
            }

            .stat-card h3 {
                font-size: 2rem;
                font-weight: 700;
                color: white;
                margin: 0;
            }

            .stat-card p {
                color: #888;
                margin: 5px 0 0;
                font-size: 0.9rem;
            }

            /* ── Tables ── */
            .table-dark {
                --bs-table-bg: var(--card-bg);
                --bs-table-border-color: rgba(108,99,255,0.2);
            }

            .content-card {
                background: var(--card-bg);
                border-radius: 16px;
                border: 1px solid rgba(108,99,255,0.2);
                padding: 25px;
                margin-bottom: 25px;
            }

            .content-card h5 {
                color: white;
                margin-bottom: 20px;
                font-weight: 600;
            }

            /* ── Buttons ── */
            .btn-primary {
                background: linear-gradient(135deg, var(--primary), #8b5cf6);
                border: none;
                border-radius: 8px;
                padding: 8px 20px;
            }

            .btn-primary:hover {
                background: linear-gradient(135deg, #8b5cf6, var(--primary));
                transform: translateY(-1px);
            }

            .page-content {
                padding: 25px;
            }

            .badge-role {
                padding: 5px 12px;
                border-radius: 20px;
                font-size: 0.75rem;
                font-weight: 600;
            }

            .badge-admin { background: rgba(245,0,87,0.2); color: #f50057; }
            .badge-teacher { background: rgba(108,99,255,0.2); color: #6c63ff; }
            .badge-student { background: rgba(0,200,150,0.2); color: #00c896; }
    </style>
</head>
<body>
    @if (User.Identity!.IsAuthenticated)
    {
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-brand">
                <h4><i class="fas fa-brain"></i> QuizMaster</h4>
                <p>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value Panel</p>
            </div>

            <nav class="mt-3">
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a class="nav-link" asp-controller="Admin" asp-action="ManageUsers">
                        <i class="fas fa-users"></i> Manage Users
                    </a>
                    <a class="nav-link" asp-controller="Admin" asp-action="ManageQuizzes">
                        <i class="fas fa-list"></i> Manage Quizzes
                    </a>
                }
                @if (User.IsInRole("Teacher"))
                {
                    <a class="nav-link" asp-controller="Teacher" asp-action="Dashboard">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a class="nav-link" asp-controller="Teacher" asp-action="MyQuizzes">
                        <i class="fas fa-list"></i> My Quizzes
                    </a>
                    <a class="nav-link" asp-controller="Teacher" asp-action="CreateQuiz">
                        <i class="fas fa-plus-circle"></i> Create Quiz
                    </a>
                }
                @if (User.IsInRole("Student"))
                {
                    <a class="nav-link" asp-controller="Student" asp-action="Dashboard">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a class="nav-link" asp-controller="Student" asp-action="AvailableQuizzes">
                        <i class="fas fa-book-open"></i> Available Quizzes
                    </a>
                    <a class="nav-link" asp-controller="Student" asp-action="MyResults">
                        <i class="fas fa-chart-bar"></i> My Results
                    </a>
                }

                <hr style="border-color: rgba(108,99,255,0.3); margin: 15px 10px;" />

                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Topbar -->
            <div class="topbar">
                <h6 class="mb-0" style="color: white;">@ViewData["Title"]</h6>
                <div class="user-info">
                    <div class="avatar">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div style="color: white; font-size: 0.9rem; font-weight: 600;">
                            @User.Identity.Name
                        </div>
                        <div style="color: #888; font-size: 0.75rem;">
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                        </div>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="page-content">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>